{
    "description": "Team1 hover gains v2 - trim values match Team1 geometry, pitch_rate kp scaled for actual Iyy (~8.7 slug*ft^2 from MAVRIK component model, NOT the suspect 0.45 from CAD).",
    "loop_rate_hz": 50,
    "mode": "hover",
    "flaps_value": 0.99,
    "trim": {
        "description": "Symmetric trim for Team1_VTOL.json. Assumes CG is exactly centered.",
        "throttle": 0.125,
        "aileron_deg": 0.0,
        "elevator_deg": 0.0,
        "rudder_deg": 0.0
    },
    "safety": {
        "max_throttle_step": 0.05,
        "max_surface_step_deg": 5.0,
        "ramp_in_seconds": 2.0,
        "warmup_seconds": 5.0
    },
    "altitude": {
        "tuning_note": "Bumped kp 0.3->0.5, kd 0.1->0.15 for faster altitude step response. Previous run showed ~15s to reach 8/10 ft \u2014 targeting ~8s.",
        "kp": 0.25,
        "ki": 0.05,
        "kd": 0.08,
        "output_min": -5.0,
        "output_max": 5.0,
        "integrator_max": 10.0
    },
    "climb_rate": {
        "tuning_note": "Bumped kp 0.02->0.04 for more aggressive collective response. ki stays the same to avoid steady-state drift.",
        "kp": 0.02,
        "ki": 0.005,
        "kd": 0.0,
        "output_min": -0.05,
        "output_max": 0.35,
        "integrator_max": 5.0
    },
    "roll_attitude": {
        "kp": 1.0,
        "ki": 0.5,
        "kd": 0.5,
        "output_min": -40.0,
        "output_max": 40.0,
        "integrator_max": 5.0
    },
    "roll_rate": {
        "tuning_note": "demo Ixx=195 slug*ft^2 with kp=0.006. Team1 Ixx printed by MAVRIK ~ check from new mass-properties output. Estimated ~8 slug*ft^2 -> kp ~ 0.006 * 8/195 = 0.00025. Use this as starting point.",
        "kp": 0.002,
        "ki": 0.0001,
        "kd": 0.0,
        "output_min": -0.08,
        "output_max": 0.08,
        "integrator_max": 3.0
    },
    "pitch_attitude": {
        "kp": 1.5,
        "ki": 0.5,
        "kd": 0.2,
        "output_min": -40.0,
        "output_max": 40.0,
        "integrator_max": 5.0
    },
    "pitch_rate": {
        "tuning_note": "Bumped kp to 0.003 for stronger pitch authority. Increased output_max to 0.15 for more differential throttle.",
        "kp": 0.001,
        "ki": 0.0001,
        "kd": 5e-05,
        "output_min": -0.08,
        "output_max": 0.08,
        "integrator_max": 3.0
    },
    "u_velocity": {
        "enabled": true,
        "kp": 0.15,
        "ki": 0.005,
        "kd": 0.0,
        "output_min": -5.0,
        "output_max": 5.0,
        "integrator_max": 5.0
    },
    "yaw_attitude": {
        "enabled": true,
        "tuning_note": "Outer loop: Drives slow arms tilt (flaps). Output limit 0.25. kp=0.01 provides proportional tilt to heading error.",
        "kp": 0.02,
        "ki": 0.001,
        "kd": 0.01,
        "output_min": -0.5,
        "output_max": 0.5,
        "integrator_max": 0.1
    },
    "yaw_rate": {
        "tuning_note": "Inner loop: Drives fast differential yaw thrust. Output limit 0.15. Damps rotation jitter.",
        "kp": 0.003,
        "ki": 0.0,
        "kd": 0.001,
        "output_min": -0.08,
        "output_max": 0.08,
        "integrator_max": 0.05
    },
    "yaw_mixer": {
        "throttle_gain": 1.0,
        "flaps_gain": 1.0,
        "_note": "throttle_gain scales the rate PID output before applying to differential throttle. flaps_gain scales the proportional flaps differential from heading error. Both default to 1.0 \u2014 adjust to balance the two yaw mechanisms."
    },
