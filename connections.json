        "filename": "aero_datalog.csv",
        "bias_error": 1.0e-5,
        "error_standard_deviation": 0.1,
        "units": "deg"
    },
    "graphics": {
        "type": "send",
        "channel_type": "udp",
        "refresh_rate": 35,
        "data_type": "state",
        "port_ID": 5005
    },
    "data_log": {
        "type": "send",
        "channel_type": "file",
        "refresh_rate": 30,
        "data_type": "both",
        "filename": "datalog.csv"
    },
    "xcontrols": {
        "type": "receive",
        "channel_type": "file",
        "refresh_rate": 100,
        "data_type": "controls",
        "filename": "pilot_commands.csv",
        "pathname": "..",
        "number_of_values": 4,
        "database_type": "rectilinear"
    }
}
