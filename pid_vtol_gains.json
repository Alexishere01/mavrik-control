{
    "description": "Team1 hover gains v2 - trim values match Team1 geometry, pitch_rate kp scaled for actual Iyy (~8.7 slug*ft^2 from MAVRIK component model, NOT the suspect 0.45 from CAD).",
    "loop_rate_hz": 50,
    "mode": "hover",
    "flaps_value": 0.99,
    "trim": {
        "description": "Trim corrected for actual CG location (x=-0.129 ft from MAVRIK component model). Effective arms: tilt=+1.87 ft, vtol=-1.76 ft. Pitch balance requires T_aft slightly HIGHER than T_fwd (opposite of what nominal motor positions would suggest, because CG sits aft of origin).",
        "throttle_fwd": 0.39,
        "throttle_aft": 0.414,
        "aileron_deg": 0.0,
        "elevator_deg": 0.0,
        "rudder_deg": 0.0,
        "lift_balance_factor": 1.0,
        "lift_balance_note": "= sin(fwd_tilt_angle). At flaps=0.99 motors are ~89.1 deg from horizontal, sin(89.1)=0.9999, so 1.0 is correct.",
        "_arm_calc": "tilt arm = 1.74-(-0.129)=1.87 ft, vtol arm = -1.89-(-0.129)=-1.76 ft. T_fwd/T_aft = 1.76/1.87 = 0.941. With W=159.6 lbf: T_aft=41.1 lbf (=0.414 throttle), T_fwd=38.7 lbf (=0.390 throttle)."
    },
    "safety": {
        "max_throttle_step": 0.05,
        "max_surface_step_deg": 5.0,
        "ramp_in_seconds": 2.0,
        "warmup_seconds": 5.0
    },
    "altitude": {
        "tuning_note": "Bumped kp 0.3->0.5, kd 0.1->0.15 for faster altitude step response. Previous run showed ~15s to reach 8/10 ft — targeting ~8s.",
