        "ki": 0.5,
        "kd": 0.2,
        "output_min": -15.0,
        "output_max": 15.0,
        "integrator_max": 5.0
    },
    "pitch_rate": {
        "tuning_note": "Bumped from 0.00025 to 0.001 (4x). At 0.00025 saw 24deg pitch peak with oscillation period ~7s -- underdamped, too slow. 4x bump targets faster catch on initial transient. Halve if oscillates.",
