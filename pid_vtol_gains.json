        "ki": 0.05,
        "kd": 0.15,
        "output_min": -5.0,
        "output_max": 5.0,
        "integrator_max": 10.0
    },
    "climb_rate": {
        "tuning_note": "Bumped kp 0.02->0.04 for more aggressive collective response. ki stays the same to avoid steady-state drift.",
        "kp": 0.04,
        "ki": 0.005,
        "kd": 0.0,
        "output_min": -0.35,
        "output_max": 0.35,
        "integrator_max": 5.0
    },
    "roll_attitude": {
        "kp": 1.5,
        "ki": 0.0,
        "kd": 0.5,
        "output_min": -15.0,
        "output_max": 15.0
